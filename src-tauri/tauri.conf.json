{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overlay Forge",
  "version": "0.4.0",
  "identifier": "com.overlayforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Overlay Forge",
        "width": 980,
        "height": 620,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false
      },
      {
        "label": "game-chat",
        "title": "Overlay Forge Chat",
        "url": "index.html?window=game-chat",
        "width": 420,
        "height": 520,
        "minWidth": 320,
        "minHeight": 210,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
