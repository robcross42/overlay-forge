local function escapeJsonString(value)
    local text = tostring(value or "")
    text = text:gsub("\\", "\\\\")
    text = text:gsub("\"", "\\\"")
    text = text:gsub("\b", "\\b")
    text = text:gsub("\f", "\\f")
    text = text:gsub("\n", "\\n")
    text = text:gsub("\r", "\\r")
    text = text:gsub("\t", "\\t")
    return "\"" .. text .. "\""
end

local function isArray(value)
    if type(value) ~= "table" then
        return false
    end
    local count = 0
    for key, _ in pairs(value) do
        if type(key) ~= "number" then
            return false
        end
        if key > count then
            count = key
        end
    end
    return true
end

local function encodeJson(value)
    local valueType = type(value)
    if valueType == "nil" then
        return "null"
    elseif valueType == "boolean" then
        return value and "true" or "false"
    elseif valueType == "number" then
        return tostring(value)
    elseif valueType == "string" then
        return escapeJsonString(value)
    elseif valueType == "table" then
        local parts = {}
        if isArray(value) then
            for index = 1, #value do
                table.insert(parts, encodeJson(value[index]))
            end
            return "[" .. table.concat(parts, ",") .. "]"
        end
        for key, item in pairs(value) do
            table.insert(parts, escapeJsonString(key) .. ":" .. encodeJson(item))
        end
        return "{" .. table.concat(parts, ",") .. "}"
    end
    return escapeJsonString(value)
end

local function vectorToTable(value)
    if value == nil then
        return nil
    end
    return {
        x = value.x or value.X or 0,
        y = value.y or value.Y or 0,
        z = value.z or value.Z or 0
    }
end

local function quaternionToTable(value)
    if value == nil then
        return nil
    end
    return {
        x = value.x or value.X or 0,
        y = value.y or value.Y or 0,
        z = value.z or value.Z or 0,
        w = value.w or value.W or 0
    }
end

local function safeRead(getter, fallback)
    local ok, value = pcall(getter)
    if ok then
        return value
    end
    return fallback
end

local function safeTry(getter)
    local ok, value = pcall(getter)
    return ok, value
end

local function addAttribute(attributes, interfaceName, attributeName, getter, normalizer)
    local valueType = "available"
    local availability = "declared"
    if normalizer ~= nil then
        availability = "declared-with-normalizer"
    end
    table.insert(attributes, {
        interface = interfaceName,
        name = attributeName,
        valueType = valueType,
        availability = availability
    })
    return true
end

local function hasAnyAttribute(target, specs)
    if target == nil then
        return false
    end
    for _, spec in ipairs(specs) do
        local ok, value = safeTry(spec)
        if ok and value ~= nil then
            return true
        end
    end
    return false
end

local function interfaceNamesFromAttributes(attributes)
    local seen = {}
    local names = {}
    for _, attribute in ipairs(attributes or {}) do
        if attribute.interface ~= nil and not seen[attribute.interface] then
            seen[attribute.interface] = true
            table.insert(names, attribute.interface)
        end
    end
    return names
end

local runtimeApiIndex = KNOWN_API_INDEX or {}

local function cloneApiAttributes(attributes)
    local cloned = {}
    for _, attribute in ipairs(attributes or {}) do
        table.insert(cloned, {
            interface = attribute.interface,
            name = attribute.name,
            valueType = attribute.valueType or "available",
            availability = attribute.availability or "declared"
        })
    end
    return cloned
end

local function apiIndexKeyForPart(part)
    if part == nil then
        return nil
    end
    local assetGuid = tostring(safeRead(function() return part.AssetGUID end, ""))
    if assetGuid ~= "" and assetGuid ~= "nil" then
        return "asset-guid:" .. assetGuid
    end
    local assetName = tostring(safeRead(function() return part.AssetName end, ""))
    if assetName ~= "" then
        return "asset-name:" .. string.lower(assetName)
    end
    local category = tostring(safeRead(function() return part.Category end, ""))
    local displayName = tostring(safeRead(function() return part.DisplayName end, safeRead(function() return part.FullDisplayName end, "")))
    if displayName ~= "" then
        return "display:" .. string.lower(category) .. ":" .. string.lower(displayName)
    end
    return nil
end

local function collectApiAttributes(value, output)
    if type(value) ~= "table" then
        return
    end
    if type(value.apiAttributes) == "table" then
        for _, attribute in ipairs(value.apiAttributes) do
            if type(attribute) == "table" and attribute.interface ~= nil and attribute.name ~= nil then
                table.insert(output, {
                    interface = attribute.interface,
                    name = attribute.name,
                    valueType = attribute.valueType or "available",
                    availability = attribute.availability or "declared"
                })
            end
        end
    end
end

local function cacheApiAttributesForPart(part, describedPart)
    local key = apiIndexKeyForPart(part)
    if key == nil or runtimeApiIndex[key] ~= nil then
        return
    end
    local attributes = {}
    collectApiAttributes(describedPart, attributes)
    if #attributes > 0 then
        runtimeApiIndex[key] = attributes
    end
end

local function apiAttributeCatalogKeyForDescribedPart(part)
    if part == nil then
        return nil
    end
    local assetGuid = tostring(part.assetGuid or "")
    if assetGuid ~= "" and assetGuid ~= "nil" then
        return "asset-guid:" .. assetGuid
    end
    local assetName = tostring(part.assetName or "")
    if assetName ~= "" then
        return "asset-name:" .. string.lower(assetName)
    end
    local category = tostring(part.category or "")
    local displayName = tostring(part.displayName or part.fullDisplayName or "")
    if displayName ~= "" then
        return "display:" .. string.lower(category) .. ":" .. string.lower(displayName)
    end
    return nil
end

local function attachApiAttributeCatalog(payload)
    if payload == nil or type(payload.parts) ~= "table" then
        return payload
    end
    local catalog = {}
    local hasCatalog = false
    for _, part in ipairs(payload.parts) do
        local attributes = part.apiAttributes
        if type(attributes) == "table" and #attributes > 0 then
            local key = apiAttributeCatalogKeyForDescribedPart(part)
            if key ~= nil then
                catalog[key] = attributes
                part.apiAttributeKey = key
                part.apiAttributes = nil
                hasCatalog = true
            end
        end
    end
    if hasCatalog then
        payload.apiAttributeCatalog = catalog
    end
    return payload
end

local function runtimeRef(value)
    if value == nil then
        return nil
    end
    return {
        id = safeRead(function() return value.ID end, nil),
        index = safeRead(function() return value.Idx end, nil),
        name = safeRead(function() return value.Name end, safeRead(function() return value.DisplayName end, "")),
        assetGuid = tostring(safeRead(function() return value.AssetGUID end, "")),
        assetName = safeRead(function() return value.AssetName end, ""),
        type = tostring(value)
    }
end

local function describeTweakable(value)
    if value == nil then
        return nil
    end
    local valueType = type(value)
    if valueType == "boolean" or valueType == "number" or valueType == "string" then
        return value
    end
    return tostring(value)
end

local function collectEnumerable(value, describer, limit)
    local items = {}
    if value == nil then
        return items
    end
    local ok = pcall(function()
        for item in value do
            table.insert(items, describer(item))
            if limit ~= nil and #items >= limit then
                break
            end
        end
    end)
    if not ok then
        return {}
    end
    return items
end

local function collectRuntimeRefs(value, limit)
    return collectEnumerable(value, runtimeRef, limit)
end

local function safeUtcDate(format)
    if os ~= nil and os.date ~= nil then
        local ok, value = pcall(function() return os.date(format) end)
        if ok and value ~= nil then
            return value
        end
    end
    return "runtime"
end

local function describeBehaviour(behaviour)
    local attributes = {}
    addAttribute(attributes, "IPartBehaviour", "DebugInfo", function() return behaviour.DebugInfo end)
    addAttribute(attributes, "IPartBehaviour", "Idx", function() return behaviour.Idx end)
