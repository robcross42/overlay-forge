function Update()
    local localPlayer = LocalPlayer.Value
    if localPlayer then
        partSelection = localPlayer.Toolbox.PartSelection
    else
        partSelection = nil
    end

    local selectionStepDistance = SelectionStepDistance.Value
    if selectionStepDistance ~= prevSelectionStepDistance then
        translationStepNumberField.Value = selectionStepDistance
        prevSelectionStepDistance = selectionStepDistance
    end

    local selectionStepAngle = SelectionStepAngle.Value
    if selectionStepAngle ~= prevSelectionStepAngle then
        rotationStepNumberField.Value = selectionStepAngle
        prevSelectionStepAngle = selectionStepAngle
    end

    local selectionResizeStepOverride = SelectionResizeUnitStepOverride.Value
    if selectionResizeStepOverride ~= prevSelectionResizeStepOverride then
        resizeStepOverrideNumberField.Value = selectionResizeStepOverride
        prevSelectionResizeStepOverride = selectionResizeStepOverride
    end

    if partSelection then
        local pivotPosition = partSelection.PivotPosition
        if not prevPivotPosition.equals(pivotPosition) then
            pivotPositionXNumberField.Value = pivotPosition.X
            pivotPositionYNumberField.Value = pivotPosition.Y
            pivotPositionZNumberField.Value = pivotPosition.Z
            prevPivotPosition = pivotPosition
        end

        local pivotOrientation = partSelection.PivotOrientation
        if not prevPivotOrientation.equals(pivotOrientation) then
            pivotOrientationXNumberField.Value = pivotOrientation.EulerAngles.X
            pivotOrientationYNumberField.Value = pivotOrientation.EulerAngles.Y
            pivotOrientationZNumberField.Value = pivotOrientation.EulerAngles.Z
            prevPivotOrientation = pivotOrientation
        end

        local pivotPartSize = Vector3.Zero
        if partSelection.IsPivotPartResizable then
            local pivotPart = partSelection.PivotPart
            if pivotPart then
                pivotPartSize = pivotPart.CurrentUnitSize
            end
        end

        if not prevPivotPartSize.equals(pivotPartSize) then
            pivotPartSizeXNumberField.Value = pivotPartSize.X
            pivotPartSizeYNumberField.Value = pivotPartSize.Y
            pivotPartSizeZNumberField.Value = pivotPartSize.Z
            prevPivotPartSize = pivotPartSize
        end
    end

    local showWeldContext = not isInGameGuiShowing()
    if showWeldContext then
        local targetedPart = nil
        if localPlayer and localPlayer.Targeter then
            targetedPart = localPlayer.Targeter.TargetedPart
        end

        if targetedPart ~= currentTargetedPart then
            if weldOwnerPart then
                setText(ownerPartLabel, string.format("From: %s", weldOwnerPart.FullDisplayName))
                if targetedPart then
                    setText(connectedPartLabel, string.format("To: %s", targetedPart.FullDisplayName))
                else
                    setText(connectedPartLabel, "To: N/A")
                end
            else
                if targetedPart then
                    setText(ownerPartLabel, string.format("From: %s", targetedPart.FullDisplayName))
                else
                    setText(ownerPartLabel, "From: N/A")
                end
                setText(connectedPartLabel, "To: N/A")
            end
            currentTargetedPart = targetedPart
        end

        if Input.GetKeyDown("tab") then
            pickPart(currentTargetedPart)
        elseif Input.GetKeyDown("delete") then
            deletePartAttachments(currentTargetedPart)
        end
    else
        currentTargetedPart = nil
    end

    if Input.GetKeyDown("e") and isControlDown() and isShiftDown() then
        onExportAll()
    end
end

