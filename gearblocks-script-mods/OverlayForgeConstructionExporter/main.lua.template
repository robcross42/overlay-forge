local function setText(element, text)
    if element == nil then
        return
    end
    pcall(function() element.Text = text end)
    pcall(function() element.text = text end)
end

local function addEventHandler(eventSource, handler)
    if eventSource ~= nil and eventSource.add ~= nil then
        eventSource.add(handler)
        return true
    end
    return false
end

local function addClickHandler(button, handler)
    if button == nil then
        return false
    end
    return addEventHandler(button.OnClick, handler) or addEventHandler(button.onClick, handler)
end

local function showWindow(window, isVisible)
    if window == nil then
        return
    end
    if window.Show ~= nil then
        pcall(function() window.Show(isVisible) end)
    elseif window.show ~= nil then
        pcall(function() window.show(isVisible) end)
    end
end

local function setVisible(element, isVisible)
    if element == nil then
        return
    end
    pcall(function() element.IsVisible = isVisible end)
    pcall(function() element.isVisible = isVisible end)
end

local function track(section, element)
    table.insert(sectionElements[section], element)
    return element
end

local function round(val)
    return math.floor(val + 0.5)
end

local function round2(val, roundTo)
    if math.abs(roundTo) > 0 then
        return round(val / roundTo) * roundTo
    end

    return val
end

local function applyWindowMinimumSize(window, section)
    local size = sectionSizes[section] or sectionSizes.home
    pcall(function() window.MinResizeWidth = size.minWidth end)
    pcall(function() window.MinResizeHeight = size.minHeight end)
end

local function centerWindowForSection(window, section)
    local size = sectionSizes[section] or sectionSizes.home
    applyWindowMinimumSize(window, section)
    pcall(function() window.SetAlignment( align_HorizCentre, 0, size.width ) end)
    pcall(function() window.SetAlignment( align_VertCentre, 0, size.height ) end)
end

