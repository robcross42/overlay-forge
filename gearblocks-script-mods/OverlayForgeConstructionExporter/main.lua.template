    addAttribute(attributes, "IConstruction", "CalcWorldBounds(bool activeStageOnly=false)", function() return construction.CalcWorldBounds(false) end, boundsToTable)
    addAttribute(attributes, "IConstruction", "CalcWorldCentreOfMass()", function() return construction.CalcWorldCentreOfMass() end, vectorToTable)
    addAttribute(attributes, "IConstruction", "CharacterPlayerID", function() return construction.CharacterPlayerID end)
    addAttribute(attributes, "IConstruction", "GetPart(ushort idx)", function()
        local firstPart = safeRead(function() return construction.GetPart(0) end, nil)
        if firstPart == nil and parts ~= nil and #parts > 0 then
            return parts[1]
        end
        return firstPart
    end, runtimeRef)
    addAttribute(attributes, "IConstruction", "ID", function() return construction.ID end)
    addAttribute(attributes, "IConstruction", "IsAtomic", function() return construction.IsAtomic end)
    addAttribute(attributes, "IConstruction", "IsBuildableBy(byte playerID)", function()
        return {
            player0 = safeRead(function() return construction.IsBuildableBy(0) end, nil),
            player1 = safeRead(function() return construction.IsBuildableBy(1) end, nil),
            player2 = safeRead(function() return construction.IsBuildableBy(2) end, nil),
            player3 = safeRead(function() return construction.IsBuildableBy(3) end, nil)
        }
    end)
    addAttribute(attributes, "IConstruction", "IsFrozen", function() return construction.IsFrozen end)
    addAttribute(attributes, "IConstruction", "IsInvulnerable", function() return construction.IsInvulnerable end)
    addAttribute(attributes, "IConstruction", "IsPlayerCharacter", function() return construction.IsPlayerCharacter end)
    addAttribute(attributes, "IConstruction", "IsSelectableBy(byte playerID)", function()
        return {
            player0 = safeRead(function() return construction.IsSelectableBy(0) end, nil),
            player1 = safeRead(function() return construction.IsSelectableBy(1) end, nil),
            player2 = safeRead(function() return construction.IsSelectableBy(2) end, nil),
            player3 = safeRead(function() return construction.IsSelectableBy(3) end, nil)
        }
    end)
    addAttribute(attributes, "IConstruction", "Mass", function() return construction.Mass end)
    addAttribute(attributes, "IConstruction", "MaxStageIdx", function() return construction.MaxStageIdx end)
    addAttribute(attributes, "IConstruction", "NumComposites", function() return construction.NumComposites end)
    addAttribute(attributes, "IConstruction", "NumParts", function() return construction.NumParts end)
    addAttribute(attributes, "IConstruction", "Parts", function() return construction.Parts end, collectRuntimeRefs)
    addAttribute(attributes, "IConstruction", "PreviewImage", function() return construction.PreviewImage end, function(value) return tostring(value) end)
    addAttribute(attributes, "IConstruction", "SetActiveStage(ushort stageIdx)", function() return construction.SetActiveStage end, function() return "available" end)
    return attributes
end

local function addOperationAvailability(attributes, interfaceName, operationName, source, memberName)
    addAttribute(attributes, interfaceName, operationName, function() return source[memberName] end, function() return "available" end)
end

describeRuntimeOperationSupport = function()
    local attributes = {}

    local attachmentOperations = safeRead(function() return AttachmentOperations end, nil)
    if attachmentOperations ~= nil then
        addOperationAvailability(attributes, "IAttachmentOperations", "CreateAttachment(...)", attachmentOperations, "CreateAttachment")
        addOperationAvailability(attributes, "IAttachmentOperations", "DeleteAllAttachments(...)", attachmentOperations, "DeleteAllAttachments")
        addOperationAvailability(attributes, "IAttachmentOperations", "DeleteAttachment(IAttachment attachment, bool invokeAsPlayer=false)", attachmentOperations, "DeleteAttachment")
        addOperationAvailability(attributes, "IAttachmentOperations", "ReplaceAttachment(IAttachment attachment, AttachmentTypeFlags newType, bool invokeAsPlayer=false)", attachmentOperations, "ReplaceAttachment")
    end

    local constructionOperations = safeRead(function() return ConstructionOperations end, nil)
    if constructionOperations ~= nil then
        addOperationAvailability(attributes, "IConstructionOperations", "AssignBuilderPlayerID(ushort constructionID, byte builderPlayerID)", constructionOperations, "AssignBuilderPlayerID")
        addOperationAvailability(attributes, "IConstructionOperations", "FreezeConstructionAndMove(...)", constructionOperations, "FreezeConstructionAndMove")
        addOperationAvailability(attributes, "IConstructionOperations", "FreezeConstructionAtGround(...)", constructionOperations, "FreezeConstructionAtGround")
        addOperationAvailability(attributes, "IConstructionOperations", "FreezeConstructionAtPlayer(...)", constructionOperations, "FreezeConstructionAtPlayer")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionCollidable(ushort constructionID, bool isCollidable)", constructionOperations, "SetConstructionCollidable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionDestroyable(ushort constructionID, bool isDestroyable)", constructionOperations, "SetConstructionDestroyable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionFrozen(ushort constructionID, bool freeze, bool invokeAsPlayer=false)", constructionOperations, "SetConstructionFrozen")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionSelectable(ushort constructionID, bool isSelectable)", constructionOperations, "SetConstructionSelectable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionTargetable(ushort constructionID, bool isTargetable)", constructionOperations, "SetConstructionTargetable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetConstructionVisible(ushort constructionID, bool isVisible)", constructionOperations, "SetConstructionVisible")
        addOperationAvailability(attributes, "IConstructionOperations", "SetPartCollidable(ushort partID, bool isCollidable)", constructionOperations, "SetPartCollidable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetPartDestroyable(ushort partID, bool isDestroyable)", constructionOperations, "SetPartDestroyable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetPartSelectable(ushort partID, bool isSelectable)", constructionOperations, "SetPartSelectable")
        addOperationAvailability(attributes, "IConstructionOperations", "SetPartsStage(ushort[] partIDs, SetStageMode setStageMode, ushort stageIdx=0)", constructionOperations, "SetPartsStage")
        addOperationAvailability(attributes, "IConstructionOperations", "SetPartVisible(ushort partID, bool isVisible)", constructionOperations, "SetPartVisible")
    end

    local partBehaviourOperations = safeRead(function() return PartBehaviourOperations end, nil)
    if partBehaviourOperations ~= nil then
        addOperationAvailability(attributes, "IPartBehaviourOperations", "ToggleActivated(IPart part)", partBehaviourOperations, "ToggleActivated")
    end

    local populateConstructions = safeRead(function() return PopConstructions end, nil)
    if populateConstructions ~= nil then
        addOperationAvailability(attributes, "IPopulateConstructions", "DestroyConstruction(ushort constructionID, bool invokeAsPlayer=false)", populateConstructions, "DestroyConstruction")
        addOperationAvailability(attributes, "IPopulateConstructions", "DestroyConstructions(ushort[] constructionIDs, bool invokeAsPlayer=false)", populateConstructions, "DestroyConstructions")
        addOperationAvailability(attributes, "IPopulateConstructions", "DestroyPart(ushort partID, bool invokeAsPlayer=false)", populateConstructions, "DestroyPart")
        addOperationAvailability(attributes, "IPopulateConstructions", "DuplicateConstruction(...)", populateConstructions, "DuplicateConstruction")
        addOperationAvailability(attributes, "IPopulateConstructions", "DuplicatePart(...)", populateConstructions, "DuplicatePart")
        addAttribute(attributes, "IPopulateConstructions", "GetPlayerConstructionID(byte playerID)", function()
            return {
                player0 = safeRead(function() return populateConstructions.GetPlayerConstructionID(0) end, nil),
                player1 = safeRead(function() return populateConstructions.GetPlayerConstructionID(1) end, nil),
                player2 = safeRead(function() return populateConstructions.GetPlayerConstructionID(2) end, nil),
                player3 = safeRead(function() return populateConstructions.GetPlayerConstructionID(3) end, nil)
            }
        end)
        addOperationAvailability(attributes, "IPopulateConstructions", "SpawnConstruction(...)", populateConstructions, "SpawnConstruction")
        addOperationAvailability(attributes, "IPopulateConstructions", "SpawnPart(...)", populateConstructions, "SpawnPart")
    end

    return {
        interfaceNames = interfaceNamesFromAttributes(attributes),
        apiAttributes = attributes
    }
end

local function describeConstruction(construction)
    local parts = {}
    local partInstances = safeRead(function() return construction.Parts end, nil)
    if partInstances ~= nil then
        for part in partInstances do
            table.insert(parts, describePart(part))
        end
    end
    local attributes = describeConstructionAttributes(construction, parts)

    return {
        exportedAt = safeUtcDate("!%Y-%m-%dT%H:%M:%SZ"),
        exporter = "OverlayForgeConstructionExporter",
        id = safeRead(function() return construction.ID end, nil),
        numComposites = safeRead(function() return construction.NumComposites end, 0),
        numParts = safeRead(function() return construction.NumParts end, #parts),
        isAtomic = safeRead(function() return construction.IsAtomic end, false),
        isPlayerCharacter = safeRead(function() return construction.IsPlayerCharacter end, false),
        isFrozen = safeRead(function() return construction.IsFrozen end, false),
        isInvulnerable = safeRead(function() return construction.IsInvulnerable end, false),
        mass = safeRead(function() return construction.Mass end, 0),
        maxStageIndex = safeRead(function() return construction.MaxStageIdx end, nil),
        activeStageIndex = safeRead(function() return construction.ActiveStageIdx end, nil),
        centreOfMass = vectorToTable(safeRead(function() return construction.CalcWorldCentreOfMass() end, nil)),
        parts = parts,
        runtimeOperationSupport = describeRuntimeOperationSupport(),
        interfaceNames = interfaceNamesFromAttributes(attributes),
        apiAttributes = attributes
    }
end

local function ensureExportDir()
    if os ~= nil and os.execute ~= nil then
        os.execute("mkdir \"" .. EXPORT_DIR .. "\"")
    end
end

local function writeFile(path, content)
    if io == nil or io.open == nil then
        return false, "Lua io.open is not available in this script context."
    end
    local file, errorMessage = io.open(path, "w")
    if file == nil then
        return false, errorMessage
    end
    file:write(content)
    file:close()
    return true, nil
end

local function safeFileName(value)
    local text = tostring(value or "construction")
    text = text:gsub("[^%w%-_%. ]", "_")
    text = text:gsub("%s+", "_")
    if text == "" then
        return "construction"
    end
    return text
end

local function emitLogExport(path, content)
    local exportId = safeFileName(path) .. "_" .. safeUtcDate("!%Y%m%d_%H%M%S")
    print("[OverlayForgeExportBegin]" .. encodeJson({
        id = exportId,
        path = path,
        length = string.len(content),
        chunkSize = LOG_CHUNK_SIZE
    }))

    local offset = 1
    while offset <= string.len(content) do
        print("[OverlayForgeExportData]" .. exportId .. "|" .. string.sub(content, offset, offset + LOG_CHUNK_SIZE - 1))
        offset = offset + LOG_CHUNK_SIZE
    end

    print("[OverlayForgeExportEnd]" .. exportId)
    return true, "Player.log"
end

local function exportPayload(payload, label)
    ensureExportDir()
    attachApiAttributeCatalog(payload)
    local fileName = safeFileName(label or tostring(payload.id or "export")) .. "_" .. safeUtcDate("!%Y%m%d_%H%M%S") .. ".json"
    local path = EXPORT_DIR .. "\\" .. fileName
    local content = encodeJson(payload)
    local ok, destination = writeFile(path, content)
    if not ok and destination == "Lua io.open is not available in this script context." then
        ok, destination = emitLogExport(path, content)
    end
    if not ok then
        setSceneExportStatus("Export failed: " .. tostring(destination))
        return false
    end
    setSceneExportStatus("Export successful: " .. tostring(payload.numParts or 0) .. " parts to " .. tostring(destination))
    return true
end

local function exportConstruction(construction, label)
    local payload = describeConstruction(construction)
    return exportPayload(payload, label or ("construction_" .. tostring(payload.id)))
end

local function exportAllSceneParts()
    if Parts == nil then
        return false
    end

    local partInstances = safeRead(function() return Parts.Instances end, nil)
    if partInstances == nil then
        return false
    end

    local parts = {}
    for part in partInstances do
        table.insert(parts, describePart(part))
    end

    if #parts == 0 then
        setSceneExportStatus("Export complete: no scene parts found.")
        return true
    end

    return exportPayload(describeSceneParts(parts), "scene_parts")
end

local function exportAllConstructions()
    local count = 0
    local exported = 0
    if Constructions == nil then
        setStatus("Constructions API is not available.")
        return
    end

    local constructionInstances = safeRead(function() return Constructions.Instances end, nil)
    if constructionInstances == nil then
        setStatus("No construction enumeration is available.")
        return
    end

    for construction in constructionInstances do
        count = count + 1
        local constructionID = safeRead(function() return construction.ID end, count)
        if exportConstruction(construction, "construction_" .. tostring(constructionID)) then
            exported = exported + 1
        end
    end
    if count == 0 then
        setStatus("No loaded constructions found.")
    else
        setStatus("Exported " .. tostring(exported) .. " of " .. tostring(count) .. " construction(s).")
    end
end

local function onExportAll()
    setSceneExportStatus("Exporting scene...")
    if not exportAllSceneParts() then
        setSceneExportStatus("Scene export API unavailable; trying loaded constructions...")
        exportAllConstructions()
    end
end

