local function pickPart(part)
    if weldOwnerPart == nil then
        weldOwnerPart = part

        if weldOwnerPart then
            setText(pickPartButton, "Complete Weld (Tab)")
            setStatus("Weld start: " .. tostring(weldOwnerPart.FullDisplayName))
        end
    else
        if part then
            local connectedPart = part

            if weldOwnerPart.Attachments.IsAttached(connectedPart) then
                setStatus("Parts already attached!")
            elseif weldOwnerPart.ParentConstruction.IsFrozen ~= connectedPart.ParentConstruction.IsFrozen then
                setStatus("Parts must be either both frozen or both unfrozen!")
            else
                local attachType = attachTypes[attachTypeDropdown.Value + 1][1]
                local searchPosition = (weldOwnerPart.Position + connectedPart.Position) * 0.5
                local searchNormal = Vector3.Normalize(connectedPart.Position - weldOwnerPart.Position)
                AttachmentOps.CreateAttachment(attachType, weldOwnerPart, connectedPart, searchPosition, searchNormal, false, true)
                setStatus("Created " .. tostring(attachTypes[attachTypeDropdown.Value + 1][2]) .. " weld.")
            end
        else
            setStatus("Weld cancelled.")
        end

        weldOwnerPart = nil
        setText(pickPartButton, "Start Weld (Tab)")
    end
    currentTargetedPart = nil
end

local function deletePartAttachments(part)
    if part then
        AttachmentOps.DeleteAllAttachments(part, true)
        setStatus("Detached targeted part.")
    end
end

