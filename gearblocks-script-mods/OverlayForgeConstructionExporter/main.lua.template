    addAttribute(attributes, "IPartBehaviour", "Name", function() return behaviour.Name end)
    addAttribute(attributes, "IPartBehaviour", "Part", function() return behaviour.Part end, runtimeRef)

    if hasAnyAttribute(behaviour, {
        function() return behaviour.ControlInfo end,
        function() return behaviour.IsControlBound end,
        function() return behaviour.IsControlOverridden end,
        function() return behaviour.OnlyControlWhenPlayerLocked end
