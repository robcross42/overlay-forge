        addAttribute(attributes, "ICheckpoint", "ConstructionHandler", function() return behaviour.ConstructionHandler end, function() return "available" end)
        addAttribute(attributes, "ICheckpoint", "HasInside(IPart part)", function() return behaviour.HasInside end, function() return "requires argument" end)
        addAttribute(attributes, "ICheckpoint", "OnConstructionEntered", function() return behaviour.OnConstructionEntered end, function() return "available" end)
